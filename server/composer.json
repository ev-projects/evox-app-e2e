{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.1.3",
        "caffeinated/modules": "4.4.0",
        "ejarnutowski/laravel-api-key": "^1.0",
        "fideloper/proxy": "^4.0",
        "ixudra/curl": "^6.19",
        "laravel/framework": "5.7.28",
        "laravel/tinker": "^1.0",
        "maatwebsite/excel": "^3.1",
        "michaelachrisco/readonly": "^0.33.0",
        "spatie/laravel-activitylog": "1.0.0",
        "spatie/laravel-cors": "^1.6",
        "spatie/laravel-permission": "^1.3",
        "tymon/jwt-auth": "^1.0.0-beta.3@dev"
    },
    "require-dev": {
        "beyondcode/laravel-dump-server": "^1.0",
        "filp/whoops": "^2.0",
        "fzaninotto/faker": "^1.4",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^2.0",
        "phpunit/phpunit": "^7.0"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/api_response_helper.php",
            "app/Helpers/bhr_helper.php",
            "app/Helpers/constants_helper.php",
            "app/Helpers/date_helper.php",
            "app/Helpers/log_helper.php",
            "app/Helpers/parse_helper.php",
            "app/Helpers/rule_helper.php",
            "app/Helpers/schedule_helper.php",
            "app/Helpers/summary_helper.php",
            "app/Helpers/user_helper.php",
            "app/Helpers/validator_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
